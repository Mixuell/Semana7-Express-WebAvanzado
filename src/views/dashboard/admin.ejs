<!DOCTYPE html>
<html lang="es">

<head><%- include('../partials/head') %>
        <title>Admin Dashboard</title>
</head>

<body>
    <nav class="red darken-2">
        <div class="nav-wrapper container">
            <a href="#" class="brand-logo">Admin Panel</a>
            <ul class="right">
                <li><a href="/profile">Mi Perfil</a></li>
                <li><a href="#" onclick="logout()">Salir</a></li>
            </ul>
        </div>
    </nav>
    <div class="container" style="margin-top:40px">
        <h5>Lista de usuarios</h5>
        <table class="striped responsive-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Apellido</th>
                    <th>Email</th>
                    <th>Roles</th>
                    <th>Registro</th>
                </tr>
            </thead>
            <tbody id="users-table"></tbody>
        </table>
    </div>
    <%- include('../partials/scripts') %>
        <script>
            const token = sessionStorage.getItem('token');
            if (!token) window.location.href = '/signIn';

            const payload = JSON.parse(atob(token.split('.')[1]));
            if (!payload.roles.includes('admin')) window.location.href = '/403';

            async function loadUsers() {
                const res = await fetch('/api/users', { headers: { 'Authorization': 'Bearer ' + token } });
                if (res.status === 401) { sessionStorage.clear(); window.location.href = '/signIn'; return; }
                if (res.status === 403) { window.location.href = '/403'; return; }
                const users = await res.json();
                const tbody = document.getElementById('users-table');
                tbody.innerHTML = users.map(u => `
        <tr>
          <td>${u.name}</td>
          <td>${u.lastName || '-'}</td>
          <td>${u.email}</td>
          <td>${u.roles.map(r => r.name).join(', ')}</td>
          <td>${new Date(u.createdAt).toLocaleDateString()}</td>
        </tr>
      `).join('');
            }

            function logout() { sessionStorage.clear(); window.location.href = '/signIn'; }
            loadUsers();
        </script>
</body>

</html>