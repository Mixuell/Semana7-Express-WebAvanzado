<!DOCTYPE html>
<html lang="es">

<head><%- include('../partials/head') %>
        <title>Dashboard</title>
</head>

<body>
    <nav class="blue darken-2">
        <div class="nav-wrapper container">
            <a href="#" class="brand-logo">Mi App</a>
            <ul id="nav-mobile" class="right">
                <li><a href="/profile">Mi Perfil</a></li>
                <li><a href="#" onclick="logout()">Salir</a></li>
            </ul>
        </div>
    </nav>
    <div class="container" style="margin-top:40px">
        <div class="card">
            <div class="card-content">
                <span class="card-title" id="welcome-msg">Bienvenido</span>
                <p>Has iniciado sesión correctamente.</p>
                <div id="user-info"></div>
            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
        <script>
            const token = sessionStorage.getItem('token');
            if (!token) window.location.href = '/signIn';

            async function loadUser() {
                const res = await fetch('/api/users/me', { headers: { 'Authorization': 'Bearer ' + token } });
                if (res.status === 401) { sessionStorage.clear(); window.location.href = '/signIn'; return; }
                const user = await res.json();
                document.getElementById('welcome-msg').textContent = `Bienvenido, ${user.name} ${user.lastName}`;
                document.getElementById('user-info').innerHTML = `
        <p><b>Email:</b> ${user.email}</p>
        <p><b>Roles:</b> ${user.roles.join(', ')}</p>
      `;
            }

            function logout() { sessionStorage.clear(); window.location.href = '/signIn'; }
            loadUser();
        </script>
</body>

</html>